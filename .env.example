# --- App ---
NEXT_PUBLIC_APP_URL="https://www.opencode.guru"
NEXT_PUBLIC_APP_NAME="opencode.guru"

# --- Auth.js ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=""

# Get from https://github.com/settings/developers
# Callback URL: https://<your-domain>/api/auth/callback/github
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Get from https://console.cloud.google.com/apis/credentials
# Callback URL: https://<your-domain>/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# --- Database ---
# On Vercel, all of these are auto-set when you connect a Supabase project.
# Locally, point at any Postgres URL.

# Connection URL used by the app (pooled — for runtime queries)
POSTGRES_URL=""

# Direct connection (for migrations / DDL — required by Supabase/PgBouncer)
POSTGRES_URL_NON_POOLING=""

# Optional: connection parts (Vercel/Supabase also provide these)
POSTGRES_HOST=""
POSTGRES_DATABASE=""
POSTGRES_USER="postgres"
POSTGRES_PASSWORD=""
POSTGRES_PRISMA_URL=""

# --- Supabase (optional — only needed if you use Supabase client features) ---
NEXT_PUBLIC_SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_PUBLISHABLE_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# --- Email (SMTP) ---
# We use SMTP via nodemailer. Works with Amazon SES SMTP, Resend,
# Postmark, Mailgun, or any other SMTP server.
#
# Two ways to configure:
#
# 1) Generic SMTP (any provider):
EMAIL_SERVER_HOST=""                 # e.g. smtp.resend.com, smtp.postmarkapp.com
EMAIL_SERVER_PORT="587"              # 587 (STARTTLS) or 465 (SSL)
EMAIL_SERVER_SECURE="false"          # "true" if port 465
EMAIL_SERVER_USER=""                 # SMTP username
EMAIL_SERVER_PASSWORD=""             # SMTP password
EMAIL_FROM=""                        # e.g. "opencode.guru <noreply@yourdomain.com>"
#
# 2) Amazon SES SMTP (alternative to the generic SMTP config above):
#    Generate SMTP credentials in AWS console → SES → SMTP settings →
#    "Create SMTP credentials". The username is NOT your AWS access key id.
AWS_SES_REGION="us-east-1"
AWS_SES_SMTP_USER=""                 # from SES → SMTP settings
AWS_SES_SMTP_PASSWORD=""             # from SES → SMTP settings
EMAIL_FROM=""                        # verified sender in SES

# --- Seed (optional) ---
# Email for the seeded SUPER_ADMIN. Defaults to admin@opencode.guru.
# You can promote a different account after signing in once:
#   UPDATE users SET role='SUPER_ADMIN' WHERE email='you@example.com';
SEED_ADMIN_EMAIL="admin@opencode.guru"

# Set to "false" to skip automatic seeding on Vercel deploys (migrations
# still run). Default: true.
SEED_ENABLED="true"